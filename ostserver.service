[Unit]
Description=OST — Observatoire Sans Tête
After=network.target

[Service]
Environment=QT_QPA_PLATFORM=offscreen
WorkingDirectory=/home/ostserver/.ost
ExecStart=/usr/bin/ostserver --webroot=/var/lib/osterix/media --indiserver=Y --loglevel=0 --grant=0
Restart=on-failure
RestartSec=5
User=ostserver

[Install]
WantedBy=multi-user.target
