#!/bin/sh
set -e

# Use the user who invoked sudo, fallback to current user
INSTALL_USER="${SUDO_USER:-${USER:-root}}"

# Patch the service file with the actual user
sed -i "s/^User=.*/User=${INSTALL_USER}/" /lib/systemd/system/ostserver.service

# Create media directory and set ownership
mkdir -p /var/lib/osterix/media
chown -R "${INSTALL_USER}" /var/lib/osterix

# Enable and start the service
if [ -d /run/systemd/system ]; then
    systemctl daemon-reload
    systemctl enable ostserver.service
    systemctl start ostserver.service || true
fi
